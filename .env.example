# Anthropic (paid). Required when running with a `claude-*` model.
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (free tier available). Required when running with a `gemini-*`
# model. Get a key at https://aistudio.google.com/apikey - it's free for
# Flash and Flash-Lite models, with reduced daily quotas.
GEMINI_API_KEY=

